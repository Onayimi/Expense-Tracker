# ─── Supabase PostgreSQL Connection Strings ───────────────────────────────────
#
# Get these from your Supabase project:
#   Dashboard → Settings → Database → Connection String
#
# DATABASE_URL  — Pooled connection (port 6543) — used at runtime by the app
# DIRECT_URL    — Direct connection (port 5432) — used for migrations only
#
# In Supabase, go to:
#   Settings → Database → Connection string → Transaction mode  → copy for DATABASE_URL
#   Settings → Database → Connection string → Session mode      → copy for DIRECT_URL
#
# Replace [YOUR-PASSWORD] with your Supabase database password.

DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:5432/postgres"
