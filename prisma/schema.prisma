generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Income Sources ──────────────────────────────────────────────────────────
model IncomeSource {
  id        String   @id @default(cuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  income    Income[]
}

// ─── Expense Categories ───────────────────────────────────────────────────────
model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]
}

// ─── Income Entries ───────────────────────────────────────────────────────────
model Income {
  id        String       @id @default(cuid())
  amount    Float
  date      DateTime
  notes     String?
  sourceId  String
  source    IncomeSource @relation(fields: [sourceId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

// ─── Expense Entries ──────────────────────────────────────────────────────────
model Expense {
  id            String            @id @default(cuid())
  amount        Float
  date          DateTime
  notes         String?
  categoryId    String
  category      ExpenseCategory   @relation(fields: [categoryId], references: [id])
  isHubbyBorrow Boolean           @default(false)
  lineItems     ExpenseLineItem[]
  hubbyBorrow   HubbyBorrow?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

// ─── Expense Line Items (optional breakdown) ──────────────────────────────────
model ExpenseLineItem {
  id          String  @id @default(cuid())
  description String
  amount      Float
  expenseId   String
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

// ─── Hubby Borrow Records ─────────────────────────────────────────────────────
model HubbyBorrow {
  id          String      @id @default(cuid())
  expenseId   String      @unique
  expense     Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  description String?
  totalAmount Float
  paidAmount  Float       @default(0)
  status      String      @default("OUTSTANDING")
  repayments  Repayment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Repayments from Hubby ────────────────────────────────────────────────────
model Repayment {
  id            String      @id @default(cuid())
  hubbyBorrowId String
  hubbyBorrow   HubbyBorrow @relation(fields: [hubbyBorrowId], references: [id], onDelete: Cascade)
  amount        Float
  date          DateTime
  notes         String?
  createdAt     DateTime    @default(now())
}

// ─── App Settings ─────────────────────────────────────────────────────────────
model AppSettings {
  id             String @id @default("1")
  appName        String @default("Vela")
  currency       String @default("USD")
  currencySymbol String @default("$")
}
